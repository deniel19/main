import base64
from Crypto.Cipher import ChaCha20

# Datele tale
nonce_b64 = "AUvERG8Uxfw="
ciphertext_b64 = "Ry4k3iS0erb4zZ20gz9eYHE+QqabJ5a5HGhgg+TCYS7ab3FFuw9Dznq78+c460kkoLyj+jNvTby4ZVSkJbktOTo/EBOY"
key = b"Fidel_Alejandro_Castro_Ruz_Cuba!"

# Decodare
nonce = base64.b64decode(nonce_b64)
ciphertext = base64.b64decode(ciphertext_b64)

# Decriptare cu PyCryptodome (suportă nonce de 8 bytes)
cipher = ChaCha20.new(key=key, nonce=nonce)
plaintext = cipher.decrypt(ciphertext)

print(f"Flag: {plaintext.decode('utf-8')}")
